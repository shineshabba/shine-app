# Telegram
BOT_TOKEN=your_telegram_bot_token_here

# SQLite database (read-only access to vpn-bot database, per D-04)
DB_PATH=/root/vpn-bot/users.db

# x-ui panel (values from ~/vpn-bot/services/xui.py)
XUI_BASE_URL=http://127.0.0.1:21008
XUI_PASSWORD=your_xui_admin_password
XUI_INBOUND_ID=2

# NOTE: Verify exact variable names by checking ~/vpn-bot/services/xui.py
# Additional variables may be required once the actual xui.py is inspected:
# XUI_USERNAME=admin  (if used)
